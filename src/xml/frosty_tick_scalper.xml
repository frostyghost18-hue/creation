<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="fts:stake">stake</variable>
    <variable id="fts:martingale">martingale</variable>
    <variable id="fts:take_profit">take_profit</variable>
    <variable id="fts:stop_loss">stop_loss</variable>
    <variable id="fts:current_stake">current_stake</variable>
    <variable id="fts:total_profit">total_profit</variable>
  </variables>

  <!-- ═══ Trade Definition ══════════════════════════════════════════════════ -->

  <block type="trade_definition" id="fts:trade_def" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="fts:market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ100V</field>
        <next>
          <block type="trade_definition_tradetype" id="fts:tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">callput</field>
            <field name="TRADETYPE_LIST">callput</field>
            <next>
              <block type="trade_definition_contracttype" id="fts:contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">CALL</field>
                <next>
                  <block type="trade_definition_candleinterval" id="fts:candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="fts:restart" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="fts:restarterr" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="fts:tradeoptions">
        <mutation has_first_barrier="false" has_second_barrier="false" has_prediction="false"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <field name="CURRENCY_LIST">USD</field>
        <value name="DURATION">
          <shadow type="math_number" id="fts:dur_shadow">
            <field name="NUM">1</field>
          </shadow>
          <block type="math_number" id="fts:dur_val">
            <field name="NUM">1</field>
          </block>
        </value>
        <value name="AMOUNT">
          <shadow type="math_number" id="fts:amt_shadow">
            <field name="NUM">0.35</field>
          </shadow>
          <block type="variables_get" id="fts:amt_ref">
            <field name="VAR" id="fts:current_stake">current_stake</field>
          </block>
        </value>
      </block>
    </statement>

    <statement name="INITIALIZATION">
      <!-- stake = 0.35 -->
      <block type="variables_set" id="fts:init_stake">
        <field name="VAR" id="fts:stake">stake</field>
        <value name="VALUE">
          <block type="math_number" id="fts:stake_num">
            <field name="NUM">0.35</field>
          </block>
        </value>
        <next>
          <!-- martingale = 2 -->
          <block type="variables_set" id="fts:init_mart">
            <field name="VAR" id="fts:martingale">martingale</field>
            <value name="VALUE">
              <block type="math_number" id="fts:mart_num">
                <field name="NUM">2</field>
              </block>
            </value>
            <next>
              <!-- take_profit = 5 -->
              <block type="variables_set" id="fts:init_tp">
                <field name="VAR" id="fts:take_profit">take_profit</field>
                <value name="VALUE">
                  <block type="math_number" id="fts:tp_num">
                    <field name="NUM">5</field>
                  </block>
                </value>
                <next>
                  <!-- stop_loss = 10 -->
                  <block type="variables_set" id="fts:init_sl">
                    <field name="VAR" id="fts:stop_loss">stop_loss</field>
                    <value name="VALUE">
                      <block type="math_number" id="fts:sl_num">
                        <field name="NUM">10</field>
                      </block>
                    </value>
                    <next>
                      <!-- current_stake = stake -->
                      <block type="variables_set" id="fts:init_cs">
                        <field name="VAR" id="fts:current_stake">current_stake</field>
                        <value name="VALUE">
                          <block type="variables_get" id="fts:cs_stake_ref">
                            <field name="VAR" id="fts:stake">stake</field>
                          </block>
                        </value>
                        <next>
                          <!-- total_profit = 0 -->
                          <block type="variables_set" id="fts:init_totprofit">
                            <field name="VAR" id="fts:total_profit">total_profit</field>
                            <value name="VALUE">
                              <block type="math_number" id="fts:zero">
                                <field name="NUM">0</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>

  <!-- ═══ After Purchase ════════════════════════════════════════════════════ -->

  <block type="after_purchase" id="fts:after_purchase" x="720" y="60">
    <statement name="AFTERPURCHASE_STACK">

      <!-- total_profit += contract profit -->
      <block type="math_change" id="fts:add_profit">
        <field name="VAR" id="fts:total_profit">total_profit</field>
        <value name="DELTA">
          <shadow type="math_number" id="fts:delta_shadow">
            <field name="NUM">1</field>
          </shadow>
          <block type="read_details" id="fts:read_profit">
            <field name="DETAIL_INDEX">4</field>
          </block>
        </value>
        <next>

          <!-- if WIN -->
          <block type="controls_if" id="fts:win_check">
            <mutation else="1"></mutation>
            <value name="IF0">
              <block type="contract_check_result" id="fts:check_win">
                <field name="CHECK_RESULT">win</field>
              </block>
            </value>

            <!-- WIN branch: reset stake, check take-profit -->
            <statement name="DO0">
              <block type="variables_set" id="fts:reset_stake">
                <field name="VAR" id="fts:current_stake">current_stake</field>
                <value name="VALUE">
                  <block type="variables_get" id="fts:reset_stake_ref">
                    <field name="VAR" id="fts:stake">stake</field>
                  </block>
                </value>
                <next>
                  <block type="controls_if" id="fts:tp_check">
                    <mutation else="1"></mutation>
                    <value name="IF0">
                      <!-- total_profit >= take_profit ? -->
                      <block type="logic_compare" id="fts:tp_compare">
                        <field name="OP">GTE</field>
                        <value name="A">
                          <block type="variables_get" id="fts:tp_profit_ref">
                            <field name="VAR" id="fts:total_profit">total_profit</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="variables_get" id="fts:tp_thresh_ref">
                            <field name="VAR" id="fts:take_profit">take_profit</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <!-- Stop: take profit hit -->
                      <block type="notify" id="fts:tp_notify">
                        <field name="NOTIFICATION_TYPE">success</field>
                        <field name="NOTIFICATION_SOUND">silent</field>
                        <value name="MESSAGE">
                          <shadow type="text" id="fts:tp_msg_sh">
                            <field name="TEXT">abc</field>
                          </shadow>
                          <block type="text" id="fts:tp_msg">
                            <field name="TEXT">✅ Take Profit reached! Bot stopped.</field>
                          </block>
                        </value>
                      </block>
                    </statement>
                    <statement name="ELSE">
                      <!-- Continue trading -->
                      <block type="trade_again" id="fts:trade_again_win"></block>
                    </statement>
                  </block>
                </next>
              </block>
            </statement>

            <!-- LOSS branch: apply martingale, check stop-loss -->
            <statement name="ELSE">
              <block type="variables_set" id="fts:apply_mart">
                <field name="VAR" id="fts:current_stake">current_stake</field>
                <value name="VALUE">
                  <block type="math_arithmetic" id="fts:mart_mult">
                    <field name="OP">MULTIPLY</field>
                    <value name="A">
                      <shadow type="math_number" id="fts:ma_sh">
                        <field name="NUM">1</field>
                      </shadow>
                      <block type="variables_get" id="fts:ma_cs_ref">
                        <field name="VAR" id="fts:current_stake">current_stake</field>
                      </block>
                    </value>
                    <value name="B">
                      <shadow type="math_number" id="fts:mb_sh">
                        <field name="NUM">2</field>
                      </shadow>
                      <block type="variables_get" id="fts:mb_mart_ref">
                        <field name="VAR" id="fts:martingale">martingale</field>
                      </block>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="controls_if" id="fts:sl_check">
                    <mutation else="1"></mutation>
                    <value name="IF0">
                      <!-- total_profit <= -stop_loss ? -->
                      <block type="logic_compare" id="fts:sl_compare">
                        <field name="OP">LTE</field>
                        <value name="A">
                          <block type="variables_get" id="fts:sl_profit_ref">
                            <field name="VAR" id="fts:total_profit">total_profit</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_arithmetic" id="fts:sl_neg">
                            <field name="OP">MULTIPLY</field>
                            <value name="A">
                              <shadow type="math_number" id="fts:sl_neg_a_sh">
                                <field name="NUM">1</field>
                              </shadow>
                              <block type="variables_get" id="fts:sl_thresh_ref">
                                <field name="VAR" id="fts:stop_loss">stop_loss</field>
                              </block>
                            </value>
                            <value name="B">
                              <shadow type="math_number" id="fts:sl_neg_b_sh">
                                <field name="NUM">-1</field>
                              </shadow>
                              <block type="math_number" id="fts:sl_neg_b">
                                <field name="NUM">-1</field>
                              </block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <!-- Stop: stop loss hit -->
                      <block type="notify" id="fts:sl_notify">
                        <field name="NOTIFICATION_TYPE">error</field>
                        <field name="NOTIFICATION_SOUND">silent</field>
                        <value name="MESSAGE">
                          <shadow type="text" id="fts:sl_msg_sh">
                            <field name="TEXT">abc</field>
                          </shadow>
                          <block type="text" id="fts:sl_msg">
                            <field name="TEXT">🛑 Stop Loss reached! Bot stopped.</field>
                          </block>
                        </value>
                      </block>
                    </statement>
                    <statement name="ELSE">
                      <!-- Continue trading -->
                      <block type="trade_again" id="fts:trade_again_loss"></block>
                    </statement>
                  </block>
                </next>
              </block>
            </statement>

          </block>
        </next>
      </block>
    </statement>
  </block>

  <!-- ═══ Before Purchase ═══════════════════════════════════════════════════ -->

  <block type="before_purchase" id="fts:before_purchase" deletable="false" x="0" y="880">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="purchase" id="fts:purchase">
        <field name="PURCHASE_LIST">CALL</field>
      </block>
    </statement>
  </block>

</xml>
